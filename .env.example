# Hugging Face — required for SAM 3D Objects (gated) + SDXL weights.
# Get one at https://huggingface.co/settings/tokens and request access at
# https://huggingface.co/facebook/sam-3d-objects
HF_TOKEN=

# RunPod — for invoking your serverless endpoint from the CLI.
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Optional: S3 / Cloudflare R2 bucket for returned .ply files.
# Without these, the handler returns base64 splat bytes inline.
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
